# --- Notebook v2 env ---
# ⚠️ ห้าม commit ค่าจริง — คัดลอกไฟล์นี้เป็น .env.local แล้วเติมค่าจริงจาก tnp-backend/.env
# ใช้ DB + ล็อกอินชุดเดียวกับ TNP (เหมือน next-accountV2)

# MariaDB ตัวเดิมของ TNP-FormHelpers (dev = พอร์ต 3307 / prod = 127.0.0.1:3306, ดู tnp-backend/.env)
DATABASE_URL="mysql://root:@localhost:3307/tnpdb"

# cookie auth ที่แชร์ข้าม subdomain — ต้องตรงกับ parent domain ของ izasskobibe.com (prod)
SHARED_AUTH_COOKIE_DOMAIN=".izasskobibe.com"

# หน้า login กลางของระบบเดิม (โดเมนเว็บ/SPA = APP_URL ของ Laravel)
LOGIN_URL="https://tnp.izasskobibe.com/login"

# namespace ของ Sanctum tokenable (User model) — ยืนยันกับ DB จริงแล้ว: App\Models\User
SANCTUM_TOKENABLE_TYPE='App\Models\User'

# (F4) ability ที่ token ต้องมีถึงจะเข้าระบบได้ — '*' = full-access ผ่านเสมอ (default '*')
# SANCTUM_REQUIRED_ABILITY="*"
# (F3) อายุสูงสุดของ token (วัน) — ไม่ตั้ง = ไม่จำกัด ; ตกลงค่ากับทีม Laravel ก่อนเปิดบังคับจริง
# SANCTUM_MAX_TOKEN_AGE_DAYS=30
# (F7) origin ที่อนุญาตให้เรียก Server Action เมื่ออยู่หลัง reverse proxy (comma-separated) — กัน CSRF
# SERVER_ACTIONS_ALLOWED_ORIGINS="notebook.izasskobibe.com"

# timezone ให้ตรงกับ Laravel
TZ="Asia/Bangkok"

# --- dev only (F6: ทำงานเฉพาะ NODE_ENV=development; build/boot บน production จะ throw ถ้าเจอ flag นี้) ---
# ข้ามการเช็ค login ทั้งหมด (proxy + getCurrentUser) เพื่อพัฒนาโดยไม่ต้องมี cookie/DB
# AUTH_DEV_BYPASS=1
# ถ้าตั้งไว้ devmode จะโหลด user จริงจาก DB ตาม id นี้แทน mock (ต้องมี DB)
# DEV_USER_ID=1
# (F6) role ของ mock user ตอน bypass — default 'sale' (ตั้งใจไม่ให้ default เป็น admin)
# DEV_USER_ROLE="admin"
# ตอน dev ตั้ง domain ให้ตรงกับที่ cookie ถูกตั้ง เช่น localhost ไม่งั้น logout ลบ cookie ไม่ออก
# SHARED_AUTH_COOKIE_DOMAIN="localhost"
